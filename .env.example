# Optional deployment settings for the root docker-compose.yml
# If .env is absent, the stack still starts with safe defaults.

COMPOSE_PROJECT_NAME=evko
TZ=Europe/Moscow

POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_DB=ebko
POSTGRES_USER=ebko
POSTGRES_PASSWORD=EbkoChangeMe123!

BACKEND_IMAGE=evko-backend:latest
BACKEND_BIND=127.0.0.1
BACKEND_PORT=18080

FRONTEND_IMAGE=evko-frontend:latest
FRONTEND_BIND=0.0.0.0
FRONTEND_PORT=80

VITE_API_BASE_URL=
VITE_USE_MOCK_DATA=false
VITE_MOCK_DELAY_MS=0
